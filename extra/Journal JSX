/**
 * Unified Notion Tasks - simplified v3
 *
 * Updates in this version:
 * - lighter dark mode with higher contrast
 * - support for page body content in the task detail view
 * - direct link out to Notion from each task detail sheet
 * - keeps the hybrid database discovery/product direction
 */

type AppView = 'tasks' | 'inbox' | 'databases';

type TaskDatabase = {
  id: string;
  name: string;
  workspace?: string;
  statuses: string[];
  icon?: string;
};

type TaskItem = {
  id: string;
  title: string;
  due?: string;
  status: string;
  assignee?: string;
  databaseId?: string;
  databaseName?: string;
  url?: string;
  createdTime: string;
  lastEditedTime: string;
  extraProperties?: Record<string, string>;
};

